<Page
    x:Class="UET_CODERANK.UI.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <ScrollViewer Padding="40,40,40,40">
        <StackPanel Spacing="24">

            <TextBlock Text="My Profile" Foreground="White" FontSize="28" FontWeight="Bold"/>

            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <PersonPicture x:Name="ProfilePic" Width="72" Height="72"/>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock x:Name="txtName" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="txtRegNo" Foreground="#888888" FontSize="13"/>
                            <TextBlock x:Name="txtEmail" Foreground="#888888" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="#2A2A2A"/>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="LeetCode Username" Foreground="#888888" FontSize="12"/>
                            <TextBlock x:Name="txtLeetcode" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Section" Foreground="#888888" FontSize="12"/>
                            <TextBlock x:Name="txtSection" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="LeetCode Stats" Foreground="White" FontSize="20" FontWeight="SemiBold"/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#25282c" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="Total Solved" Foreground="#888888" FontSize="12" TextAlignment="Center"/>
                        <TextBlock x:Name="txtTotal" Text="—" Foreground="White" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#25282c" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="Easy" Foreground="#00b8a3" FontSize="12" TextAlignment="Center"/>
                        <TextBlock x:Name="txtEasy" Text="—" Foreground="#00b8a3" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#25282c" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="Medium" Foreground="#ffc01e" FontSize="12" TextAlignment="Center"/>
                        <TextBlock x:Name="txtMedium" Text="—" Foreground="#ffc01e" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#25282c" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <TextBlock Text="Hard" Foreground="#ef4743" FontSize="12" TextAlignment="Center"/>
                        <TextBlock x:Name="txtHard" Text="—" Foreground="#ef4743" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Global Rank" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtRating" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Last Synced" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtLastSync" Foreground="White" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Button x:Name="btnUpdateProfile"
                    Content="Edit Profile"
                    HorizontalAlignment="Left"
                    Padding="20,10"
                    CornerRadius="8"
                    Click="btnUpdateProfile_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>