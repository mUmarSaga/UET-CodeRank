<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UET_CODERANK.UI.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UET_CODERANK.UI"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MainBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
        <StackPanel Spacing="24">

            <!-- Welcome header -->
            <StackPanel Spacing="4">
                <TextBlock x:Name="txtWelcome"
                           Text="Welcome back, Umar 👋"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"/>
                <TextBlock x:Name="txtLastSync"
                           Text="Last synced: Never"
                           Foreground="#888888"
                           FontSize="12"/>
            </StackPanel>

            <!-- Stats cards row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Score" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtScore" Text="0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="Score" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Total Solved -->
                <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Total Solved" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtTotalSolved" Text="0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="problems" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Global Rank -->
                <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Global Rank" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtGlobalRank" Text="#0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="worldwide" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Contest Rating -->
                <Border Grid.Column="3" Background="#1A1A1A" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Contest Rating" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtContestRating" Text="0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="rating" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Contests Attended -->
                <Border Grid.Column="4" Background="#1A1A1A" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Contests" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtContests" Text="0" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="attended" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Charts row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Donut chart - problems breakdown -->
                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Problems Breakdown"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <lvc:PieChart x:Name="donutChart"
                                      Height="200"
                                      LegendPosition="Right"/>

                        <!-- Legend -->
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="12" Height="12" CornerRadius="6" Background="#00B8A3"/>
                                <TextBlock x:Name="txtEasy" Text="Easy: 0" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="12" Height="12" CornerRadius="6" Background="#FFC01E"/>
                                <TextBlock x:Name="txtMedium" Text="Medium: 0" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="12" Height="12" CornerRadius="6" Background="#FF375F"/>
                                <TextBlock x:Name="txtHard" Text="Hard: 0" Foreground="#888888" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Weekly progress bar chart -->
                <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Weekly Progress"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <lvc:CartesianChart x:Name="weeklyChart"
                                            Height="200"
                                            TooltipPosition="Top"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Badges section -->
            <Border Background="#1A1A1A" CornerRadius="12" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Badges"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"/>

                    <ItemsRepeater x:Name="badgesRepeater">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="120" MinItemHeight="120" MinColumnSpacing="12" MinRowSpacing="12"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A" CornerRadius="10" Padding="12">
                                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                                        <FontIcon Glyph="&#xE734;" Foreground="#107C10" FontSize="28"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>