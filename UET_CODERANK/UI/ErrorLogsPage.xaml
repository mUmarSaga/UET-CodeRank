<Page
    x:Class="UET_CODERANK.UI.ErrorLogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Error Logs" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock x:Name="txtSubtitle" Foreground="#888888" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <Button Content="Refresh" Padding="16,8" CornerRadius="8" Click="btnRefresh_Click"/>
            <Button Content="Clear All Logs" Padding="16,8" CornerRadius="8"
                    Background="#c0392b" Foreground="White" Click="btnClearAll_Click"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#25282c" CornerRadius="12" Padding="0">
            <StackPanel>
                <Grid Padding="20,14" Background="#1e2124">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Time" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Source" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Error Message" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Details" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <StackPanel x:Name="logRows"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

    </Grid>
</Page>