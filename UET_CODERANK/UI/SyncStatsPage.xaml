<Page
    x:Class="UET_CODERANK.UI.SyncStatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Sync Student Stats" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Fetch latest LeetCode data for all approved students." Foreground="#888888" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <Button x:Name="btnSyncAll" Content="Sync All Students" Padding="20,10"
                    CornerRadius="8" Click="btnSyncAll_Click"/>
            <TextBlock x:Name="txtSyncStatus" Foreground="#888888" FontSize="13"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <ProgressBar x:Name="syncProgress" Grid.Row="2"
                     IsIndeterminate="False" Visibility="Collapsed"
                     HorizontalAlignment="Stretch"/>

        <Border Grid.Row="3" Background="#25282c" CornerRadius="12" Padding="0">
            <StackPanel>
                <Grid Padding="20,14" Background="#1e2124">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Student" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="LeetCode" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Total" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Score" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Last Synced" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Action" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                    <StackPanel x:Name="studentRows"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

    </Grid>
</Page> 