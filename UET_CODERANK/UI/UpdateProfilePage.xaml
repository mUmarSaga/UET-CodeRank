<Page
    x:Class="UET_CODERANK.UI.UpdateProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <ScrollViewer Padding="40,40,40,40">
        <StackPanel Spacing="20">

            <TextBlock Text="Edit Profile" Foreground="White" FontSize="28" FontWeight="Bold"/>

            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Profile Info" Foreground="White" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Full Name" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="NameBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter your full name"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Email" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="EmailBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter your email"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="LeetCode Username" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="LeetcodeBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter your LeetCode username"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Display Name" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="ProfileNameBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter a display name"/>
                    </StackPanel>

                    <Button x:Name="SaveProfileBtn" Content="Save Changes"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            CornerRadius="8" Click="SaveProfileBtn_Click"/>

                    <TextBlock x:Name="ProfileStatusText" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Change Password" Foreground="White" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Current Password" Foreground="#888888" FontSize="12"/>
                        <PasswordBox x:Name="CurrentPasswordBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter current password"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="New Password" Foreground="#888888" FontSize="12"/>
                        <PasswordBox x:Name="NewPasswordBox" Background="#1e2124" Foreground="White" PlaceholderText="Enter new password"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Confirm New Password" Foreground="#888888" FontSize="12"/>
                        <PasswordBox x:Name="ConfirmPasswordBox" Background="#1e2124" Foreground="White" PlaceholderText="Confirm new password"/>
                    </StackPanel>

                    <Button x:Name="SavePasswordBtn" Content="Update Password"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            CornerRadius="8" Click="SavePasswordBtn_Click"/>

                    <TextBlock x:Name="PasswordStatusText" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>