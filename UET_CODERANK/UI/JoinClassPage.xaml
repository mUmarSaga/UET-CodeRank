<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UET_CODERANK.UI.JoinClassPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UET_CODERANK.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MainBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111" Padding="24,20"
                BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="Join a Class"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock Text="Select your batch and section to send a join request"
                           Foreground="#888888"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel Spacing="16">

                <!-- Pending request banner -->
                <Border x:Name="pendingBanner"
        Visibility="Collapsed"
        Background="#1A2A1A"
        CornerRadius="10"
        Padding="16,12"
        BorderBrush="#107C10"
        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE783;" Foreground="#107C10" FontSize="18"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="You have a pending request"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtPendingInfo"
                           Text=""
                           Foreground="#888888"
                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#2A1A1A"
                                BorderBrush="#C42B1C"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                VerticalAlignment="Center">
                                            <Button x:Name="btnCancelRequest"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Click="btnCancelRequest_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE711;" Foreground="#C42B1C" FontSize="13"/>
                                    <TextBlock Text="Cancel Request"
                               Foreground="#C42B1C"
                               FontSize="12"
                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                    </Grid>
                </Border>

                <!-- Already approved banner -->
                <Border x:Name="approvedBanner"
                        Visibility="Collapsed"
                        Background="#1A1A2A"
                        CornerRadius="10"
                        Padding="16,12"
                        BorderBrush="#0078D4"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE73E;" Foreground="#0078D4" FontSize="18"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="You are already enrolled"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtApprovedInfo"
                                       Text=""
                                       Foreground="#888888"
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <!-- Filter -->
                <Border Background="#1A1A1A" CornerRadius="10" Padding="16,12">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE71C;" Foreground="#888888" FontSize="16"/>
                        <TextBlock Text="Filter by Department:" 
                   Foreground="#888888" 
                   FontSize="13"
                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbDepartment"
                  PlaceholderText="All Departments"
                  MinWidth="200"
                  Background="#111111"
                  Foreground="White"
                  BorderBrush="#2A2A2A"
                  SelectionChanged="cmbDepartment_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <!-- Batches list -->
                <StackPanel x:Name="batchesPanel" Spacing="12"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>