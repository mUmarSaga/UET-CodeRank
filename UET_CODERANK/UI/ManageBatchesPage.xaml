<Page
    x:Class="UET_CODERANK.UI.ManageBatchesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <Grid Padding="40" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Batches Panel -->
        <StackPanel Grid.Column="0" Spacing="16">
            <TextBlock Text="Batches" Foreground="White" FontSize="22" FontWeight="Bold"/>

            <Border Background="#25282c" CornerRadius="12" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Batch" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtBatchName" PlaceholderText="Batch name e.g. 2025"
                             Background="#1e2124" Foreground="White"/>
                    <Button Content="Add Batch" HorizontalAlignment="Stretch"
                            Padding="0,10" CornerRadius="8" Click="btnAddBatch_Click"/>
                    <TextBlock x:Name="txtBatchStatus" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="#25282c" CornerRadius="12" Padding="0">
                <StackPanel>
                    <Grid Padding="16,12" Background="#1e2124">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Batch Name" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Sections" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Action" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>
                    <StackPanel x:Name="batchRows"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Sections Panel -->
        <StackPanel Grid.Column="1" Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Sections" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtSelectedBatch" Foreground="#888888" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Background="#25282c" CornerRadius="12" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Section" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtSectionName" PlaceholderText="Section name e.g. A"
                             Background="#1e2124" Foreground="White"/>
                    <Button Content="Add Section" HorizontalAlignment="Stretch"
                            Padding="0,10" CornerRadius="8" Click="btnAddSection_Click"/>
                    <TextBlock x:Name="txtSectionStatus" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="#25282c" CornerRadius="12" Padding="0">
                <StackPanel>
                    <Grid Padding="16,12" Background="#1e2124">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Section Name" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Action" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </Grid>
                    <StackPanel x:Name="sectionRows"/>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</Page>