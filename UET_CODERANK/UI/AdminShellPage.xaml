<Page
    x:Class="UET_CODERANK.UI.AdminShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#111111" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
            <StackPanel>

                <!-- Admin Info -->
                <Border Padding="16,24,16,16" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="⚙ Admin Panel" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="txtAdminName" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Nav Buttons -->
                <StackPanel Padding="10,16,10,0" Spacing="4">

                    <Button x:Name="btnDashboard"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnDashboard_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE80F;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Dashboard" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnEnrollments"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnEnrollments_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8FA;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Enrollments" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnBatches"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnBatches_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7C5;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Batches &amp; Sections" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnSync"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnSync_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE895;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Sync Stats" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnBadges"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnBadges_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE734;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Award Badges" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnReports"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnReports_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE9F9;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Reports" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnErrorLogs"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnErrorLogs_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7BA;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Error Logs" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnManageAdmins"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,10" CornerRadius="8"
                            Click="btnManageAdmins_Click">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE716;" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Manage Admins" Foreground="White" FontSize="14"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Logout at bottom -->
                <Button x:Name="btnLogout"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" BorderThickness="0"
                        Padding="22,10" CornerRadius="8"
                        VerticalAlignment="Bottom"
                        Margin="10,0,10,16"
                        Click="btnLogout_Click">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xF3B1;" Foreground="#c0392b" FontSize="16"/>
                        <TextBlock Text="Logout" Foreground="#c0392b" FontSize="14"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- Content Frame -->
        <Frame x:Name="adminContentFrame" Grid.Column="1"/>

    </Grid>
</Page>