<Page
    x:Class="UET_CODERANK.UI.ManageAdminsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Manage Admins" Foreground="White" FontSize="28" FontWeight="Bold"/>

        <Border Grid.Row="1" Background="#25282c" CornerRadius="12" Padding="24">
            <StackPanel Spacing="16">
                <TextBlock Text="Add New Admin" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="txtNewUsername" PlaceholderText="Username" Background="#1e2124" Foreground="White"/>
                    <PasswordBox Grid.Column="1" x:Name="txtNewPassword" PlaceholderText="Password" Background="#1e2124" Foreground="White"/>
                    <Button Grid.Column="2" Content="Add Admin" Padding="16,10" CornerRadius="8" Click="btnAddAdmin_Click"/>
                </Grid>
                <TextBlock x:Name="txtAddStatus" Foreground="Red" FontSize="13"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#25282c" CornerRadius="12" Padding="24">
            <StackPanel Spacing="12">
                <TextBlock Text="Existing Admins" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                <ListView x:Name="AdminList" Background="Transparent" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{Binding Username}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Created_at}" Foreground="#888888" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="(You)" Foreground="#888888" FontSize="13" VerticalAlignment="Center"
                                           Visibility="{Binding IsCurrent}"/>
                                <Button Grid.Column="2" Content="Delete" Padding="12,6" CornerRadius="6"
                                        Background="#c0392b" Foreground="White"
                                        Tag="{Binding Username}"
                                        Click="btnDeleteAdmin_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</Page>