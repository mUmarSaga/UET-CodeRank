<Page
    x:Class="UET_CODERANK.UI.AdminDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="24">

            <StackPanel Spacing="4">
                <TextBlock x:Name="txtWelcome" Foreground="White" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Here's what's happening in your department." Foreground="#888888" FontSize="13"/>
            </StackPanel>

            <!-- Stat Cards -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#25282c" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Total Students" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtTotalStudents" Text="—" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="registered" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#25282c" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Pending Requests" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtPendingRequests" Text="—" Foreground="#FFC01E" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="awaiting approval" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#25282c" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Total Batches" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtTotalBatches" Text="—" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="active" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#25282c" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Total Sections" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="txtTotalSections" Text="—" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="active" Foreground="#888888" FontSize="11"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Quick Actions -->
            <TextBlock Text="Quick Actions" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

            <StackPanel Orientation="Horizontal" Spacing="12">

                <Button Content="View Enrollment Requests" Padding="16,10" CornerRadius="8"
                        Click="btnGoEnrollments_Click"/>

                <Button Content="Manage Batches &amp; Sections" Padding="16,10" CornerRadius="8"
                        Click="btnGoBatches_Click"/>

                <Button Content="Sync Student Stats" Padding="16,10" CornerRadius="8"
                        Click="btnGoSync_Click"/>

            </StackPanel>

            <!-- Recent Enrollments -->
            <TextBlock Text="Recent Enrollment Requests" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

            <Border Background="#25282c" CornerRadius="12" Padding="0">
                <StackPanel>
                    <Grid Padding="20,14" Background="#1e2124">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Student" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Section" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Requested" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Status" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                    <StackPanel x:Name="recentEnrollmentRows"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>