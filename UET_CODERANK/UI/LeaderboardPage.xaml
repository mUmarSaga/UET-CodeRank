<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UET_CODERANK.UI.LeaderboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UET_CODERANK.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource MainBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Filters -->
        <Border Grid.Row="0" Background="#111111" Padding="24,20" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE734;" Foreground="#107C10" FontSize="24"/>
                    <StackPanel>
                        <TextBlock Text="Leaderboard"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtStudentCount"
                                   Text="0 students ranked"
                                   Foreground="#888888"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">

                    <ComboBox x:Name="cmbBatch"
                              PlaceholderText="All Batches"
                              MinWidth="160"
                              Background="#1A1A1A"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              SelectionChanged="cmbBatch_SelectionChanged"/>

                    <ComboBox x:Name="cmbSection"
                              PlaceholderText="All Sections"
                              MinWidth="140"
                              Background="#1A1A1A"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              SelectionChanged="cmbSection_SelectionChanged"/>

                    <ComboBox x:Name="cmbSortBy"
                              PlaceholderText="Sort by"
                              MinWidth="160"
                              Background="#1A1A1A"
                              Foreground="White"
                              BorderBrush="#2A2A2A"
                              SelectionChanged="cmbSortBy_SelectionChanged">
                        <ComboBoxItem Content="Total Solved" IsSelected="True"/>
                        <ComboBoxItem Content="Hard Solved"/>
                        <ComboBoxItem Content="Contest Rating"/>
                        <ComboBoxItem Content="Global Rank"/>
                    </ComboBox>

                    <Button x:Name="btnReset"
                            Content="Reset Filters"
                            Background="Transparent"
                            BorderBrush="#2A2A2A"
                            Foreground="#888888"
                            CornerRadius="6"
                            Padding="12,8"
                            Click="btnReset_Click"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel Spacing="24">

                <!-- Top 3 podium -->
                <Grid x:Name="podiumGrid" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 2nd place -->
                    <Border Grid.Column="0"
                            Background="#1A1A1A"
                            CornerRadius="16"
                            Padding="20"
                            BorderBrush="#C0C0C0"
                            BorderThickness="1"
                            Margin="0,24,0,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <Border Background="#2A2A2A"
                                    CornerRadius="30"
                                    Width="60" Height="60"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🥈"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txt2ndName"
                                       Text="—"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="txt2ndReg"
                                       Text=""
                                       Foreground="#888888"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <Border Background="#2A2A2A" CornerRadius="20" Padding="12,6" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="txt2ndSolved"
                                               Text="0"
                                               Foreground="#C0C0C0"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="solved"
                                               Foreground="#888888"
                                               FontSize="11"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,2"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="2nd Place"
                                       Foreground="#C0C0C0"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 1st place - tallest -->
                    <Border Grid.Column="1"
                            Background="#1A1A1A"
                            CornerRadius="16"
                            Padding="20"
                            BorderBrush="#FFD700"
                            BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <TextBlock Text="👑"
                                       FontSize="28"
                                       HorizontalAlignment="Center"/>
                            <Border Background="#2A2A2A"
                                    CornerRadius="36"
                                    Width="72" Height="72"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🥇"
                                           FontSize="36"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txt1stName"
                                       Text="—"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="txt1stReg"
                                       Text=""
                                       Foreground="#888888"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <Border Background="#107C10" CornerRadius="20" Padding="16,8" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="txt1stSolved"
                                               Text="0"
                                               Foreground="White"
                                               FontSize="22"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="solved"
                                               Foreground="#B4B4B4"
                                               FontSize="11"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,3"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="1st Place"
                                       Foreground="#FFD700"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 3rd place -->
                    <Border Grid.Column="2"
                            Background="#1A1A1A"
                            CornerRadius="16"
                            Padding="20"
                            BorderBrush="#CD7F32"
                            BorderThickness="1"
                            Margin="0,40,0,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <Border Background="#2A2A2A"
                                    CornerRadius="30"
                                    Width="60" Height="60"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="🥉"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txt3rdName"
                                       Text="—"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="txt3rdReg"
                                       Text=""
                                       Foreground="#888888"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <Border Background="#2A2A2A" CornerRadius="20" Padding="12,6" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="txt3rdSolved"
                                               Text="0"
                                               Foreground="#CD7F32"
                                               FontSize="18"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="solved"
                                               Foreground="#888888"
                                               FontSize="11"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,0,2"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="3rd Place"
                                       Foreground="#CD7F32"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Full leaderboard table -->
                <Border Background="#1A1A1A" CornerRadius="12" Padding="0">

                    <!-- Table header -->
                    <StackPanel>
                        <Grid Padding="20,14" Background="#111111">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Rank" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Student" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="Easy" Foreground="#00B8A3" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Medium" Foreground="#FFC01E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Hard" Foreground="#FF375F" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="Total" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="Contest Rating" Foreground="#888888" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Rows loaded in code -->
                        <StackPanel x:Name="leaderboardRows"/>
                    </StackPanel>

                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>