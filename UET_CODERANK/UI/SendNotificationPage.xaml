<Page
    x:Class="UET_CODERANK.UI.SendNotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource MainBackground}">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="24">

            <StackPanel Spacing="4">
                <TextBlock Text="Send Notification" Foreground="White" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="Send a message to a specific student or broadcast to all." Foreground="#888888" FontSize="13"/>
            </StackPanel>

            <!-- Send to specific student -->
            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Send to Student" Foreground="White" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Select Student" Foreground="#888888" FontSize="12"/>
                        <ComboBox x:Name="cmbStudents" HorizontalAlignment="Stretch"
                                  PlaceholderText="Choose a student"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Message" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="txtStudentMessage" PlaceholderText="Type your message here..."
                                 Background="#1e2124" Foreground="White"
                                 AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Content="Send to Student" HorizontalAlignment="Stretch"
                            Padding="0,12" CornerRadius="8" Click="btnSendToStudent_Click"/>

                    <TextBlock x:Name="txtStudentStatus" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Broadcast to all -->
            <Border Background="#25282c" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Broadcast to All Students" Foreground="White" FontSize="16" FontWeight="SemiBold"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Message" Foreground="#888888" FontSize="12"/>
                        <TextBox x:Name="txtBroadcastMessage" PlaceholderText="Type your broadcast message..."
                                 Background="#1e2124" Foreground="White"
                                 AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Content="Broadcast to All" HorizontalAlignment="Stretch"
                            Padding="0,12" CornerRadius="8"
                            Background="#c0392b" Foreground="White"
                            Click="btnBroadcast_Click"/>

                    <TextBlock x:Name="txtBroadcastStatus" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>